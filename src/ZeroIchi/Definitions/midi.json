{
  "name": "MIDI",
  "extensions": ["mid", "midi"],
  "magic": "4D 54 68 64",
  "endian": "big",
  "fields": [
    {
      "id": "header",
      "name": "Header Chunk",
      "type": "group",
      "fields": [
        { "id": "chunkType", "name": "Chunk Type", "type": "text", "size": 4 },
        { "id": "chunkLength", "name": "Chunk Length", "type": "uint32" },
        { "id": "format", "name": "Format", "type": "uint16" },
        { "id": "numTracks", "name": "Number of Tracks", "type": "uint16" },
        { "id": "division", "name": "Division", "type": "uint16" }
      ]
    },
    {
      "id": "tracks",
      "name": "Tracks",
      "type": "repeat",
      "until": "eof",
      "nameTemplate": "Track Chunk",
      "fields": [
        { "id": "chunkType", "name": "Chunk Type", "type": "text", "size": 4 },
        { "id": "chunkLength", "name": "Chunk Length", "type": "uint32" },
        {
          "id": "trackData",
          "name": "Track Data",
          "type": "repeat",
          "size": "chunkLength",
          "nameTemplate": "${event}",
          "fields": [
            { "id": "deltaTime", "name": "Delta Time", "type": "vlq" },
            { "id": "status", "name": "Status", "type": "uint8", "peekMin": 128 },
            {
              "id": "event",
              "name": "Event",
              "type": "match",
              "on": "status",
              "cases": [
                {
                  "name": "Meta Event",
                  "range": [255, 255],
                  "fields": [
                    { "id": "metaType", "name": "Meta Type", "type": "uint8" },
                    {
                      "id": "body",
                      "name": "Body",
                      "type": "match",
                      "on": "metaType",
                      "cases": [
                        {
                          "name": "Text",
                          "range": [1, 7],
                          "fields": [
                            { "id": "length", "name": "Length", "type": "vlq" },
                            { "id": "text", "name": "Text", "type": "text", "size": "length" }
                          ]
                        },
                        {
                          "name": "Data",
                          "range": [0, 0],
                          "fields": [
                            { "id": "length", "name": "Length", "type": "vlq" },
                            { "id": "data", "name": "Data", "type": "bytes", "size": "length" }
                          ]
                        },
                        {
                          "name": "Data",
                          "range": [8, 255],
                          "fields": [
                            { "id": "length", "name": "Length", "type": "vlq" },
                            { "id": "data", "name": "Data", "type": "bytes", "size": "length" }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "name": "SysEx",
                  "range": [240, 240],
                  "fields": [
                    { "id": "length", "name": "Length", "type": "vlq" },
                    { "id": "data", "name": "Data", "type": "bytes", "size": "length" }
                  ]
                },
                {
                  "name": "SysEx Escape",
                  "range": [247, 247],
                  "fields": [
                    { "id": "length", "name": "Length", "type": "vlq" },
                    { "id": "data", "name": "Data", "type": "bytes", "size": "length" }
                  ]
                },
                {
                  "name": "Note Off",
                  "range": [128, 143],
                  "fields": [
                    { "id": "note", "name": "Note", "type": "uint8" },
                    { "id": "velocity", "name": "Velocity", "type": "uint8" }
                  ]
                },
                {
                  "name": "Note On",
                  "range": [144, 159],
                  "fields": [
                    { "id": "note", "name": "Note", "type": "uint8" },
                    { "id": "velocity", "name": "Velocity", "type": "uint8" }
                  ]
                },
                {
                  "name": "Poly Pressure",
                  "range": [160, 175],
                  "fields": [
                    { "id": "note", "name": "Note", "type": "uint8" },
                    { "id": "pressure", "name": "Pressure", "type": "uint8" }
                  ]
                },
                {
                  "name": "Control Change",
                  "range": [176, 191],
                  "fields": [
                    { "id": "controller", "name": "Controller", "type": "uint8" },
                    { "id": "value", "name": "Value", "type": "uint8" }
                  ]
                },
                {
                  "name": "Program Change",
                  "range": [192, 207],
                  "fields": [
                    { "id": "program", "name": "Program", "type": "uint8" }
                  ]
                },
                {
                  "name": "Channel Pressure",
                  "range": [208, 223],
                  "fields": [
                    { "id": "pressure", "name": "Pressure", "type": "uint8" }
                  ]
                },
                {
                  "name": "Pitch Bend",
                  "range": [224, 239],
                  "fields": [
                    { "id": "lsb", "name": "LSB", "type": "uint8" },
                    { "id": "msb", "name": "MSB", "type": "uint8" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
